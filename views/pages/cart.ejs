<%- include('../partials/header') %>

<main class="cart-container">
    <div class="cart-wrapper">

        <h1 class="cart-title">Tu Carrito</h1>

        <div id="cart-vacio" class="cart-vacio" style="display:none;">
            <i class="fas fa-shopping-cart"></i>
            <p>Tu carrito está vacío</p>
            <a href="/" class="btn-volver">Volver al listado</a>
        </div>

        <div id="cart-contenido">
            <div id="cart-items" class="cart-items"></div>

            <div class="cart-footer">
                <div class="cart-total">
                    <span>Total:</span>
                    <span id="cart-total-puntos">0 PUNTOS</span>
                </div>
                <div class="cart-acciones">
                    <a href="/" class="btn-volver">Volver al listado</a>
                    <a href="/checkout" class="btn-pagar">Ir a Pagar</a>
                </div>
            </div>
        </div>

    </div>
</main>

<script src="/js/cart.js"></script> <%- include('../partials/footer') %>