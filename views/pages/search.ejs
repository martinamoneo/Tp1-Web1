<main>
    <section class="products-section">

        <% if (query && query.trim() !== '') { %>
            <h2>Resultados para: "<%= query %>"</h2>
        <% } else { %>
            <h2>Ingresá un término para buscar</h2>
        <% } %>

        <% if (resultados.length > 0) { %>
            <div class="products-grid">
                <% resultados.forEach(producto => { %>
                    <%- include('../partials/productCard', { producto: producto }) %>
                <% }); %>
            </div>
        <% } else if (query && query.trim() !== '') { %>
            <p class="search-no-results">
                No encontramos productos que coincidan con "<strong><%= query %></strong>".
            </p>
        <% } %>

    </section>
</main>

<%- include('../partials/panelProducto') %>

<script>
    window.listaProductosGlobal = JSON.parse('<%- JSON.stringify(resultados) %>');
</script>
<script src="/js/productDetail.js"></script>