<%- include('../partials/header') %>

<main>
    <!-- categorias -->
    <section class="home-container">
        <nav class="categories-nav">
            <ul class="categories-list">
                <li><i class="fas fa-whiskey-glass"></i><span>Mates</span></li>
                <li><i class="fas fa-beer"></i><span>Vasos</span></li>
                <li><i class="fas fa-key"></i><span>Llaveros</span></li>
                <li><i class="fas fa-crop-simple"></i><span>Soportes</span></li>
                <li><i class="fas fa-trophy"></i><span>Premios</span></li>
                <li><i class="fas fa-snowman"></i><span>Munecos</span></li>
                <li><i class="fa-regular fa-lightbulb"></i><span>Lamparas</span></li>
                <li class="last-item"><i class="fas fa-gift"></i><span>Otros</span></li>
            </ul>
        </nav>
    </section>
    <!-- novedades e ingresos -->
    <section class="banner-section">
        <div class="banner-container">
            <article class="banner-card banner-card1" onclick="abrirPanelDesdeBanner('novedades')">
                <div class="banner-content">
                    <div class="banner-text">
                        <h3>Novedades</h3>
                        <p>Descubre lo último que llegó</p>
                    </div>
                </div>
            </article>

            <article class="banner-card banner-card2" onclick="abrirPanelDesdeBanner('proximos')">
                <div class="banner-content">
                    <div class="banner-text">
                        <h3>Próximos Ingresos</h3>
                        <p>Lo que pronto estará disponible</p>
                    </div>
                </div>
            </article>
        </div>
    </section>
    <!-- lo mas pedido -->
    <section class="products-section lo-mas-pedido-section" style="padding-bottom: 10px;">
        <h2>Lo más pedido</h2>
        <div class="carousel-wrapper">
            <button class="sugeridos-btn izquierda carousel-btn" onclick="scrollCarousel(-1, 'loMasPedidoTrack')">
                <i class="fa-solid fa-angle-left"></i>
            </button>
            <div class="carousel-grid" id="loMasPedidoTrack">
                <% 
                    const productosMasPedidos = [...listaProductos].slice(0, 10);
                    productosMasPedidos.forEach(producto => { 
                %>
                    <%- include('../partials/productCard', { producto: producto }) %>
                <% }); %>
            </div>
            <button class="sugeridos-btn derecha carousel-btn" onclick="scrollCarousel(1, 'loMasPedidoTrack')">
                <i class="fa-solid fa-angle-right"></i>
            </button>
        </div>
    </section>
    <!-- te puede interesar -->
    <section class="products-section" style="padding-bottom: 10px;">
        <h2>Te puede interesar</h2>
        <div class="products-grid">
            <% 
                const productosInteres = [...listaProductos].sort(() => 0.5 - Math.random()).slice(0, 5);
                productosInteres.forEach(producto => { 
            %>
                <%- include('../partials/productCard', { producto: producto }) %>
            <% }); %>
        </div>
    </section>
    <!-- productos -->
    <section class="products-section">
        <h2>Mira nuestros productos!</h2>
        <div class="products-grid">
            <% listaProductos.forEach(producto => { %>
                <%- include('../partials/productCard', { producto: producto }) %>
            <% }); %>
        </div>
    </section>

</main>

<!-- PANEL DESPLEGABLE (fuera del main para evitar conflictos) -->
<div id="panelProducto" class="panel-producto">
    <div class="panel-contenido">

        <button class="panel-close" onclick="cerrarPanel()">✕</button>

        <div class="panel-info-row">
            <div class="panel-izquierda">
                <div class="panel-galeria">
                    <div class="slider-container">
                        <img id="panelImagen" src="" alt="" class="panel-img-principal" onerror="this.onerror=null; this.src='/img/no-image.png'">
                    </div>
                </div>
            </div>

            <div class="panel-derecha">
                <p id="panelCategoria" class="panel-categoria"></p>
                <h2 id="panelNombre"></h2>
                <p id="panelPuntos" class="panel-puntos"></p>
                <p id="panelDescripcion" class="panel-descripcion"></p>
                <hr class="panel-divisor">
                <a id="panelDetalleLink" href="#" class="panel-detalle-link">Ver detalles completos y ficha técnica &rarr;</a>
                
                <div class="panel-acciones">
                    <div class="cantidad-selector">
                        <button class="btn-cantidad" onclick="cambiarCantidadPanel(-1)">
                            <i class="fa-solid fa-minus"></i>
                        </button>
                        <input type="text" id="panelCantidad" value="1" readonly>
                        <button class="btn-cantidad" onclick="cambiarCantidadPanel(1)">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>
                    <button class="btn-carrito" id="btnAgregarCarrito" onclick="agregarAlCarrito()">
                        AGREGAR AL CARRITO
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    window.listaProductosGlobal = ('<%- JSON.stringify(listaProductos) %>');
</script>
<script>
const productosSugeridosData = JSON.parse('<%- JSON.stringify(productosSugeridos) %>');
</script>
<script src="/js/productDetail.js"></script>
<script src="/js/home.js"></script> 

<%- include('../partials/footer') %>